   "source": [
    "def fib(n):\n",
    "    sqroot = 5**0.5\n",
    "    phi = (sqroot + 1) / 2\n",
    "    return int(phi ** n / sqroot + 0.5)\n",
    "\n",
    "print(fib(10))"
   ]
  },
